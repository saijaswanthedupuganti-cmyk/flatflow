rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isMember(flatId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
    }

    function isAdmin(flatId) {
      return isMember(flatId)
        && get(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Flats ─────────────────────────────────────────────────────────────────
    match /flats/{flatId} {
      // Any authenticated user can read (needed for joining with invite code)
      allow read: if request.auth != null;
      // Any authenticated user can create a flat (they become admin via server-set field)
      allow create: if request.auth != null;
      // Only admin can update or delete their flat
      allow update, delete: if isAdmin(flatId);

      // ── Members ─────────────────────────────────────────────────────────────
      match /members/{memberId} {
        // Only flat members can read the members list
        allow read: if isMember(flatId);
        // Members can write their own doc; admin can write any member's doc
        allow write: if request.auth != null
          && (
            request.auth.uid == memberId
            || isAdmin(flatId)
          );
      }

      // ── Tasks ─────────────────────────────────────────────────────────────
      match /tasks/{taskId} {
        // All members can read tasks
        allow read: if isMember(flatId);
        // Only admin can create or delete tasks
        allow create, delete: if isAdmin(flatId);
        // Any member can update a task (mark complete, check overdue, etc.)
        allow update: if isMember(flatId);
      }

      // ── Activity Log ────────────────────────────────────────────────────────
      match /activityLog/{activityId} {
        // All members can read
        allow read: if isMember(flatId);
        // Members can create entries; userId must be their own UID or 'system'
        allow create: if isMember(flatId)
          && (
            request.resource.data.userId == request.auth.uid
            || request.resource.data.userId == 'system'
          );
        // Activity log is append-only — no updates or deletes
      }

      // ── Swap Requests ───────────────────────────────────────────────────────
      match /swapRequests/{requestId} {
        // All members can read swap requests
        allow read: if isMember(flatId);
        // Any member can create a swap request
        allow create: if isMember(flatId);
        // Only the intended recipient (toUserId) can accept or reject
        allow update: if isMember(flatId)
          && resource.data.toUserId == request.auth.uid;
        // No deletes on swap requests (keeps history intact)
      }
    }
  }
}
