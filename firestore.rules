rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isMember(flatId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
    }

    function isAdmin(flatId) {
      return isMember(flatId)
        && get(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Seeker Profiles (any logged-in user, read by all authenticated) ──────
    // Users post "I'm looking for a flat" profiles here. Admins can read these
    // to discover potential flatmates. Users can only write their own profile.
    match /seekerProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Discovery Tags (global, shared across all flats) ─────────────────────
    // Authenticated users can read all tags (for autocomplete).
    // Any authenticated user may create a tag; tags are permanent (no update/delete).
    match /discoveryTags/{tagId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Rewards subcollection ──────────────────────────────────────────────
      // Written by the server-side task-completion logic (useFlatStore) under the
      // completing user's UID. Read by that user only in their profile Wallet.
      // Only `isRedeemed` may be updated (when the user copies their code).
      match /rewards/{rewardId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRedeemed']);
        allow delete: if false;
      }
    }

    // ── Reward Pool (admin-managed via Firebase Console, read-only for clients) ─
    // Admins create/update documents here: { brandName, discountCode, description,
    // isActive, expiryDays }. The app reads active rewards and picks one per task
    // completion. Update a code here → all users get it automatically (6h cache).
    match /rewardPool/{rewardId} {
      allow read: if request.auth != null;
      allow write: if false; // Firebase Console / Admin SDK only
    }

    // ── Coupons ───────────────────────────────────────────────────────────────
    // Coupon docs live at /coupons/{CODE} and are created via Firebase Console.
    // Client can read (to validate) and append its flatId to usedBy (to redeem).
    match /coupons/{code} {
      allow read: if request.auth != null;
      // Only permitted mutation: append one flatId to the usedBy array
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy'])
        && request.resource.data.usedBy.size() == resource.data.usedBy.size() + 1;
      allow create, delete: if false;
    }

    // ── Flats ─────────────────────────────────────────────────────────────────
    match /flats/{flatId} {
      // Any authenticated user can read (needed to validate invite codes)
      allow read: if request.auth != null;
      // Any authenticated user can create a flat (they become admin)
      allow create: if request.auth != null;
      // Admin can update anything on the flat document
      // Non-admin joining: may increment memberCount by exactly 1 (and touch ONLY that field)
      // Non-admin leaving: may decrement memberCount by exactly 1 (and touch ONLY that field,
      //   but only while they are still a member — call this BEFORE deleting the member doc)
      allow update: if isAdmin(flatId)
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
          && request.resource.data.memberCount == resource.data.get('memberCount', 0) + 1
        )
        || (
          isMember(flatId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
          && request.resource.data.memberCount == resource.data.get('memberCount', 0) - 1
        );
      allow delete: if isAdmin(flatId);

      // ── Members ─────────────────────────────────────────────────────────────
      match /members/{memberId} {
        // Members can read the list.
        // A non-member can also read their own (potential) doc so that joinFlat
        // can check "am I already a member?" without a permissions error.
        allow read: if isMember(flatId)
          || (request.auth != null && request.auth.uid == memberId);

        // A user may join (create their own member doc) only when:
        //  - they are authenticated
        //  - they are creating their own record (not someone else's)
        //  - the flat has fewer than 8 members (enforced via memberCount field)
        allow create: if request.auth != null
          && request.auth.uid == memberId
          && get(/databases/$(database)/documents/flats/$(flatId)).data.get('memberCount', 0) < 8;

        // Members can update/delete their own doc (status, nickname, etc.).
        // Admin can update/delete any member doc (kick, role transfer).
        // Any flat member may update only the `status` field of another member — needed
        // for OOS auto-trigger when a swap request is accepted on a different user's device.
        allow update, delete: if request.auth != null
          && (
            request.auth.uid == memberId
            || isAdmin(flatId)
            || (
              isMember(flatId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            )
          );
      }

      // ── Tasks ─────────────────────────────────────────────────────────────
      match /tasks/{taskId} {
        // All members can read tasks
        allow read: if isMember(flatId);
        // Only admin can create or delete tasks
        allow create, delete: if isAdmin(flatId);
        // Any member can update a task (mark complete, check overdue, etc.)
        allow update: if isMember(flatId);
      }

      // ── Activity Log ────────────────────────────────────────────────────────
      match /activityLog/{activityId} {
        // All members can read
        allow read: if isMember(flatId);
        // Members can create entries; userId must be their own UID or 'system'
        allow create: if isMember(flatId)
          && (
            request.resource.data.userId == request.auth.uid
            || request.resource.data.userId == 'system'
          );
        // Admin can update entries (used to toggle the hidden field — soft hide without deleting)
        allow update: if isAdmin(flatId);
        // Admin can delete (needed for flat deletion)
        allow delete: if isAdmin(flatId);
      }

      // ── NPS Responses ───────────────────────────────────────────────────────
      match /npsResponses/{responseId} {
        // Admin can read all responses for their flat
        allow read: if isAdmin(flatId);
        // Any member can submit once (create only their own response)
        allow create: if isMember(flatId)
          && request.resource.data.uid == request.auth.uid;
        // No updates or deletes
        allow update, delete: if false;
      }

      // ── Swap Requests ───────────────────────────────────────────────────────
      match /swapRequests/{requestId} {
        // All members can read swap requests
        allow read: if isMember(flatId);
        // Any member can create a swap request
        allow create: if isMember(flatId);
        // Only the intended recipient (toUserId) can accept or reject.
        // The requester (fromUserId) can: mark their own notification as read, OR
        // withdraw (cancel) their pending request by setting status → 'rejected'.
        allow update: if isMember(flatId)
          && (
            resource.data.toUserId == request.auth.uid
            || (
              resource.data.fromUserId == request.auth.uid
              && (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
                || (
                  request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                  && resource.data.status == 'pending'
                  && request.resource.data.status == 'rejected'
                )
              )
            )
          );
        // Admin can delete (needed for flat deletion and kick cleanup)
        allow delete: if isAdmin(flatId);
      }

      // ── Expenses ────────────────────────────────────────────────────────────
      match /expenses/{expenseId} {
        allow read: if isMember(flatId);
        allow create: if isMember(flatId)
          && request.resource.data.createdBy == request.auth.uid;
        allow delete: if isMember(flatId)
          && (resource.data.createdBy == request.auth.uid || isAdmin(flatId));
        allow update: if isMember(flatId)
          && (resource.data.createdBy == request.auth.uid || isAdmin(flatId));
      }

      // ── Settlements ──────────────────────────────────────────────────────────
      match /settlements/{settlementId} {
        allow read: if isMember(flatId);
        // Either party (payer OR receiver) may record the settlement — the creditor
        // recording a "Mark Received" sets fromUserId = debtor, so we must allow
        // toUserId == auth.uid as well.
        allow create: if isMember(flatId)
          && (
            request.resource.data.fromUserId == request.auth.uid
            || request.resource.data.toUserId == request.auth.uid
          );
        allow delete: if isMember(flatId)
          && (
            resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
            || isAdmin(flatId)
          );
        allow update: if false;
      }

      // ── Recurring Bills ──────────────────────────────────────────────────────
      match /recurringBills/{billId} {
        allow read: if isMember(flatId);
        allow create, update, delete: if isAdmin(flatId);
      }

      // ── Bill Instances ────────────────────────────────────────────────────────
      // One instance per recurring bill per month. Separate from ad-hoc expenses.
      match /billInstances/{instanceId} {
        // All members can read
        allow read: if isMember(flatId);
        // Admin creates instances (via generateBill)
        // Members can record a one-time bill they personally paid (Record a Bill I Paid)
        allow create: if (isAdmin(flatId) && request.resource.data.generatedBy == request.auth.uid)
          || (isMember(flatId)
              && request.resource.data.isOneTime == true
              && request.resource.data.generatedBy == request.auth.uid
              && request.resource.data.paidBy == request.auth.uid);
        // Admin can update any field (skip, edit amount, etc.)
        // Payer can mark paid and update collection tracking
        // Designated collector can update collection tracking
        // Any member can self-mark their own collectedFrom entry (tap Pending → Received)
        allow update: if isAdmin(flatId)
          || (isMember(flatId) && resource.data.paidBy == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paidAt', 'collectedFrom']))
          || (isMember(flatId) && resource.data.collectorId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collectedFrom']))
          || (isMember(flatId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collectedFrom']));
        // Admin can delete (needed for flat deletion)
        allow delete: if isAdmin(flatId);
      }

      // ── Month Cycles ─────────────────────────────────────────────────────────
      // One document per flat per month. Backbone of the monthly lifecycle.
      match /monthCycles/{cycleId} {
        // All members can read (needed to display carry-forward, history)
        allow read: if isMember(flatId);
        // Admin creates and updates (open/close cycle)
        allow create, update: if isAdmin(flatId);
        // No delete — month history is permanent
        allow delete: if false;
      }

      // ── Behavioral Events (Discovery / Trust Tag) ─────────────────────────────
      // Immutable event log. Never trimmed. Only the event owner can write their own.
      // Admin can read for auditing. No updates or deletes — append-only.
      match /behavioralEvents/{eventId} {
        allow read: if isMember(flatId);
        allow create: if isMember(flatId)
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Join Requests ────────────────────────────────────────────────────────
      // Used when the flat is in 'approval' mode. Non-members submit requests;
      // the admin approves or rejects them.
      match /joinRequests/{requestId} {
        // Admin reads all pending requests; requester can read their own status
        allow read: if isAdmin(flatId)
          || (request.auth != null && resource.data.uid == request.auth.uid);
        // Any authenticated user may submit a join request for themselves
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        // Admin can approve/reject (update status) or delete
        allow update, delete: if isAdmin(flatId);
      }
    }
  }
}
