rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flat document: any authenticated user can read (for joining with code)
    // Only the admin can create/delete the flat
    match /flats/{flatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid)).data.role == 'admin';

      // Members: admin can write all, members can only write their own doc
      match /members/{memberId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
        allow write: if request.auth != null
          && (
            request.auth.uid == memberId
            || (
              exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid))
              && get(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid)).data.role == 'admin'
            )
          );
      }

      // Tasks: all members can read; admin or assigned member can write
      match /tasks/{taskId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
        allow write: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
      }

      // Activity log: all members can read; all can write (create entries)
      match /activityLog/{activityId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
      }

      // Swap requests: all members can read and create; resolver or admin can update
      match /swapRequests/{requestId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
        allow update: if request.auth != null
          && exists(/databases/$(database)/documents/flats/$(flatId)/members/$(request.auth.uid));
      }
    }
  }
}
